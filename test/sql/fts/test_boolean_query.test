field_weights contains unknown field: missing

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    field_b := MAP {'title': 1.1}
)
----
field b for title must be finite and between 0 and 1

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    field_b := MAP {'missing': 0.5}
)
----
field_b contains unknown field: missing

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    scoring_model := 'bm25f',
    tie_breaker := 0.1
)
----
tie_breaker is only supported with best_fields scoring

# Invalid query trees fail before returning search results.
statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query(NULL)
----
query must be a non-null JSON object

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('[]'::JSON)
----
query must be a non-null JSON object

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{}'::JSON)
----
Boolean group must contain at least one must or should clause

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"must_not":[{"query":"alpha"}]}'::JSON)
----
Boolean group must contain at least one must or should clause

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","must":[]}'::JSON)
----
query node cannot contain both query and Boolean clauses

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":42}'::JSON)
----
query leaf must contain a string query

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","unknown":true}'::JSON)
----
query node contains unknown key: unknown

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","query":"beta"}'::JSON)
----
query node contains duplicate keys

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"must":{"query":"alpha"}}'::JSON)
----
must must be an array

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"must":["alpha"]}'::JSON)
----
must entries must be JSON objects

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","fields":[]}'::JSON)
----
fields must be a non-empty array of field names

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","fields":[1]}'::JSON)
----
fields entries must be non-empty strings without commas or surrounding whitespace

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","fields":[" title "]}'::JSON)
----
fields entries must be non-empty strings without commas or surrounding whitespace

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","fields":["missing"]}'::JSON)
----
fields contains unknown field: missing

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","query_mode":"invalid"}'::JSON)
----
query_mode must be either standard or autocomplete

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","boost":-1}'::JSON)
----
boost must be finite and non-negative

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"query":"alpha","boost":"high"}'::JSON)
----
boost must be finite and non-negative

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"should":[{"query":"alpha"}],"minimum_should_match":2}'::JSON)
----
minimum_should_match must be a non-negative integer no greater than the number of should clauses

statement error
SELECT * FROM fts_main_boolean_docs.search_layered_bm25_query('{"should":[{"query":"alpha"}],"minimum_should_match":0.5}'::JSON)
----
minimum_should_match must be a non-negative integer no greater than the number of should clauses

# The default leaf limit is deliberately larger than the original fixed boundary.
query I
SELECT count(*)
FROM fts_main_boolean_docs.search_layered_bm25_query(
    json_object(
        'should',
        list_transform(range(65), lambda ignored: json_object('query', 'alpha'))
    )
)
----
3

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    json_object(
        'should',
        list_transform(range(65), lambda ignored: json_object('query', 'alpha'))
    ),
    max_leaf_clauses := 64
)
----
query exceeds max_leaf_clauses of 64

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    json_object(
        'should',
        list_transform(range(1025), lambda ignored: json_object('query', 'alpha'))
    )
)
----
query exceeds max_leaf_clauses of 1024

# The scalar API forwards the same caller-controlled resource policy.
statement error
SELECT fts_main_boolean_docs.match_layered_bm25_query(
    'd1',
    json_object(
        'should',
        list_transform(range(2), lambda ignored: json_object('query', 'alpha'))
    ),
    max_leaf_clauses := 1
)
----
query exceeds max_leaf_clauses of 1

# The recursive reducer is not tied to the original eight generated CTE levels.
query I
SELECT count(*)
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"query":"alpha"}]}]}]}]}]}]}]}]}]}'::JSON
)
----
3

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"query":"alpha"}]}]}]}]}]}]}]}]}]}'::JSON,
    max_boolean_depth := 8
)
----
query exceeds max_boolean_depth of 8

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"query":"alpha"}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}'::JSON
)
----
query exceeds max_boolean_depth of 64

query I
SELECT count(*)
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"must":[{"query":"alpha"}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}'::JSON,
    max_boolean_depth := 100
)
----
3

# NULL disables either caller-controlled limit.
query I
SELECT count(*)
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    max_leaf_clauses := NULL,
    max_boolean_depth := NULL
)
----
3

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    max_leaf_clauses := 0
)
----
max_leaf_clauses must be NULL or a positive integer

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    max_boolean_depth := -1
)
----
max_boolean_depth must be NULL or a positive integer

statement error
SELECT *
FROM fts_main_boolean_docs.search_layered_bm25_query(
    '{"query":"alpha"}'::JSON,
    max_boolean_depth := 1.5
)
