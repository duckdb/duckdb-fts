# name: test/sql/fts/test_field_scoring.test
# description: Per-field BM25 normalization, weighting, best-fields scoring, and maintenance
# group: [fts]

require skip_reload

require fts

require no_alternative_verify

statement ok
CREATE TABLE documents(id VARCHAR NOT NULL, title VARCHAR, body VARCHAR)

statement ok
INSERT INTO documents VALUES
    ('title_match', 'alpha alpha', 'noise noise noise noise'),
    ('body_match', 'noise noise', 'alpha alpha'),
    ('both_match', 'alpha', 'alpha'),
    ('empty', NULL, '')

statement ok
PRAGMA create_fts_index('documents', 'id', 'title', 'body', stemmer='none', stopwords='none', layered_search=true)

# Per-field lengths are aligned with fieldid, including zero-token fields.
query IIII rowsort
SELECT name, len, field_lens::VARCHAR, docid
FROM fts_main_documents.docs
----
body_match	4	[2, 2]	1
both_match	2	[1, 1]	2
empty	0	[0, 0]	3
title_match	6	[2, 4]	0

query III
SELECT num_docs, avgdl, avg_field_lens::VARCHAR
FROM fts_main_documents.stats
----
4	3.0	[1.25, 1.75]

# The default path must remain the original whole-document BM25 formula.
query I
WITH term_tf AS (
    SELECT terms.docid, terms.termid, count(*) AS tf
    FROM fts_main_documents.terms AS terms
    JOIN fts_main_documents.dict AS dict USING (termid)
    WHERE dict.term = 'alpha'
    GROUP BY terms.docid, terms.termid
), expected AS (
    SELECT docs.name,
           log(((stats.num_docs - dict.df + 0.5) / (dict.df + 0.5)) + 1)
           * ((term_tf.tf * 2.2) / (term_tf.tf + 1.2 * (0.25 + 0.75 * (docs.len / stats.avgdl)))) AS score
    FROM term_tf
    JOIN fts_main_documents.docs AS docs USING (docid)
    JOIN fts_main_documents.dict AS dict USING (termid)
    CROSS JOIN fts_main_documents.stats AS stats
), actual AS (
    SELECT id AS name, fts_main_documents.match_bm25(id, 'alpha') AS score
    FROM documents
)
SELECT count(*) = 3 AND bool_and(abs(expected.score - actual.score) < 1e-12)
FROM expected
JOIN actual USING (name)
----
true

# With exact expansion disabled, layered defaults retain the same scores.
query I
WITH layered AS (
    SELECT docname, score
    FROM fts_main_documents.search_layered_bm25(
        'alpha',
        top_k := NULL,
        enable_prefix := false,
        enable_substring := false,
        enable_fuzzy := false,
        enable_short_fuzzy := false
    )
), base AS (
    SELECT id AS docname, fts_main_documents.match_bm25(id, 'alpha') AS score
    FROM documents
)
SELECT count(*) = 3 AND bool_and(abs(layered.score - base.score) < 1e-12)
FROM layered
JOIN base USING (docname)
----
true

# A weight affects only the configured field; omitted fields default to 1.
query III
WITH scores AS (
    SELECT id,
           fts_main_documents.match_bm25(id, 'alpha', field_weights := MAP {}) AS unweighted,
           fts_main_documents.match_bm25(id, 'alpha', field_weights := MAP {'title': 4.0}) AS weighted,
           fts_main_documents.match_bm25(id, 'alpha', field_weights := MAP {'title': 4.0, 'body': 1.0}) AS explicit_body
    FROM documents
)
SELECT round(max(weighted / unweighted) FILTER (id = 'title_match'), 12) = 4,
       round(max(weighted / unweighted) FILTER (id = 'body_match'), 12) = 1,
       bool_and(weighted = explicit_body) FILTER (weighted IS NOT NULL)
FROM scores
----
true	true	true

# Field filtering is applied before weighting, and a zero weight suppresses that field's score.
query II
SELECT
    abs(
        fts_main_documents.match_bm25('body_match', 'alpha', fields := 'body', field_weights := MAP {'title': 100.0})
        - fts_main_documents.match_bm25('body_match', 'alpha', fields := 'body', field_weights := MAP {})
    ) < 1e-12,
    fts_main_documents.match_bm25('title_match', 'alpha', field_weights := MAP {'title': 0.0}) = 0
----
true	true

# best_fields uses max + tie_breaker * (sum - max).
query III
WITH components AS (
    SELECT
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {'body': 0.0}) AS title_score,
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {'title': 0.0}) AS body_score,
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {}) AS sum_score,
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {}, field_mode := 'best_fields') AS best_score,
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {}, field_mode := 'best_fields', tie_breaker := 0.5) AS half_score,
        fts_main_documents.match_bm25('both_match', 'alpha', field_weights := MAP {}, field_mode := 'best_fields', tie_breaker := 1.0) AS full_score
)
SELECT abs(sum_score - (title_score + body_score)) < 1e-12,
       abs(best_score - greatest(title_score, body_score)) < 1e-12,
       abs(half_score - (greatest(title_score, body_score) + 0.5 * least(title_score, body_score))) < 1e-12
           AND abs(full_score - sum_score) < 1e-12
FROM components
----
true	true	true

query I
SELECT docname
FROM fts_main_documents.search_layered_bm25(
    'alpha',
    field_weights := MAP {'title': 100.0},
    enable_prefix := false,
    enable_substring := false,
    enable_fuzzy := false,
    enable_short_fuzzy := false
)
ORDER BY rank
LIMIT 1
----
title_match

# Field-aware scoring also applies after prefix, fuzzy, and autocomplete expansion.
statement ok
CREATE TABLE expansion_docs(id VARCHAR NOT NULL, title VARCHAR, body VARCHAR)

statement ok
INSERT INTO expansion_docs VALUES
    ('title_expansion', 'zephyr', 'noise'),
    ('body_expansion', 'noise', 'zeppelin')

statement ok
PRAGMA create_fts_index('expansion_docs', 'id', 'title', 'body', stemmer='none', stopwords='none', layered_search=true)

query I
SELECT string_agg(docname, ',' ORDER BY rank)
FROM fts_main_expansion_docs.search_layered_bm25(
    'zep',
    field_weights := MAP {'title': 4.0},
    enable_substring := false,
    enable_fuzzy := false,
    enable_short_fuzzy := false
)
----
title_expansion,body_expansion

query I
SELECT docname
FROM fts_main_expansion_docs.search_layered_bm25(
    'zephr',
    field_weights := MAP {'title': 4.0},
    enable_prefix := false,
    enable_substring := false
)
ORDER BY rank
LIMIT 1
----
title_expansion

query I
SELECT string_agg(docname, ',' ORDER BY rank)
FROM fts_main_expansion_docs.search_layered_bm25(
    'zep',
    query_mode := 'autocomplete',
    field_weights := MAP {'title': 4.0}
)
----
title_expansion,body_expansion

# Invalid field-scoring configuration fails before returning results.
statement error
SELECT fts_main_documents.match_bm25('title_match', 'alpha', field_mode := 'invalid')
----
field_mode must be either sum or best_fields

statement error
SELECT * FROM fts_main_documents.search_layered_bm25('alpha', field_mode := NULL)
----
field_mode must be either sum or best_fields

statement error
SELECT fts_main_documents.match_bm25('title_match', 'alpha', tie_breaker := 1.5)
----
tie_breaker must be finite and between 0 and 1

statement error
SELECT * FROM fts_main_documents.search_layered_bm25('alpha', tie_breaker := 'NaN'::DOUBLE)
----
tie_breaker must be finite and between 0 and 1

statement error
SELECT fts_main_documents.match_bm25('title_match', 'alpha', field_weights := MAP {'title': -1.0})
----
field weight for title must be finite and non-negative

statement error
SELECT * FROM fts_main_documents.search_layered_bm25('alpha', field_weights := MAP {'title': NULL::DOUBLE})
----
field weight for title must be finite and non-negative

statement error
SELECT fts_main_documents.match_bm25('title_match', 'alpha', field_weights := MAP {'missing': 1.0})
----
field_weights contains unknown field: missing

# Regular incremental maintenance keeps per-field lengths and averages current.
statement ok
CREATE TABLE live_docs(id VARCHAR NOT NULL, title VARCHAR, body VARCHAR)

statement ok
INSERT INTO live_docs VALUES
    ('live1', 'alpha alpha', 'beta'),
    ('live2', NULL, 'alpha beta beta')

statement ok
PRAGMA create_fts_index('live_docs', 'id', 'title', 'body', stemmer='none', stopwords='none', layered_search=true, incremental=true)

statement ok
INSERT INTO live_docs VALUES ('live3', 'alpha', '')

statement ok
DELETE FROM live_docs WHERE id = 'live1'

query II rowsort
SELECT name, field_lens::VARCHAR
FROM fts_main_live_docs.docs
----
live2	[0, 3]
live3	[1, 0]

query II
SELECT avgdl, avg_field_lens::VARCHAR
FROM fts_main_live_docs.stats
----
2.0	[0.5, 1.5]

# Incremental scores match a clean rebuild of the same table state.
statement ok
CREATE TABLE rebuilt_docs AS SELECT * FROM live_docs

statement ok
PRAGMA create_fts_index('rebuilt_docs', 'id', 'title', 'body', stemmer='none', stopwords='none', layered_search=true)

query I
WITH live_scores AS (
    SELECT docname, score
    FROM fts_main_live_docs.search_layered_bm25(
        'alpha',
        top_k := NULL,
        field_weights := MAP {'title': 3.0},
        field_mode := 'best_fields',
        tie_breaker := 0.25,
        enable_prefix := false,
        enable_substring := false,
        enable_fuzzy := false,
        enable_short_fuzzy := false
    )
), rebuilt_scores AS (
    SELECT docname, score
    FROM fts_main_rebuilt_docs.search_layered_bm25(
        'alpha',
        top_k := NULL,
        field_weights := MAP {'title': 3.0},
        field_mode := 'best_fields',
        tie_breaker := 0.25,
        enable_prefix := false,
        enable_substring := false,
        enable_fuzzy := false,
        enable_short_fuzzy := false
    )
)
SELECT count(*) = 2 AND bool_and(abs(live_scores.score - rebuilt_scores.score) < 1e-12)
FROM live_scores
JOIN rebuilt_scores USING (docname)
----
true

# The clustered incremental terms path maintains the same field statistics.
statement ok
CREATE TABLE clustered_docs(id VARCHAR NOT NULL, title VARCHAR, body VARCHAR)

statement ok
INSERT INTO clustered_docs VALUES
    ('clustered1', 'alpha', 'beta beta'),
    ('clustered2', NULL, 'alpha')

statement ok
PRAGMA create_fts_index('clustered_docs', 'id', 'title', 'body', stemmer='none', stopwords='none', incremental=true, cluster_terms=true)

statement ok
INSERT INTO clustered_docs VALUES ('clustered3', 'alpha alpha', '')

statement ok
DELETE FROM clustered_docs WHERE id = 'clustered1'

query II rowsort
SELECT name, field_lens::VARCHAR
FROM fts_main_clustered_docs.docs
----
clustered2	[0, 1]
clustered3	[2, 0]

query II
SELECT avgdl, avg_field_lens::VARCHAR
FROM fts_main_clustered_docs.stats
----
1.5	[1.0, 0.5]
